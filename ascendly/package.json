{
  "name": "ascendly",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "android:staging": "cross-env ENVFILE=.env.staging npx react-native run-android --mode=stagingDebug --appIdSuffix=staging",
    "android:prod": "cross-env ENVFILE=.env npx react-native run-android --mode=productionDebug --appIdSuffix=''",
    "android:s": "npm run android:staging",
    "android:sl": "npm run android:staging && npm run logs",
    "android:p": "npm run android:prod",
    "android:pl": "npm run android:prod && npm run logs",
    "android:id": "react-native run-android --deviceId",
    "logs": "react-native log-android",
    "lint": "eslint .",
    "format": "prettier --write .",
    "lint:fix": "eslint . --fix && npm run format",
    "prepare": "husky install",
    "start": "react-native start",
    "start:staging": "cross-env ENVFILE=.env.staging npx react-native start --reset-cache",
    "start:prod": "cross-env ENVFILE=.env npx react-native start --reset-cache",
    "test": "jest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-firebase/analytics": "^24.0.0",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/auth": "^24.0.0",
    "@react-native-firebase/crashlytics": "^24.0.0",
    "@react-native-firebase/firestore": "^24.0.0",
    "@react-native-firebase/in-app-messaging": "^24.0.0",
    "@react-native-firebase/messaging": "^24.0.0",
    "@react-native-google-signin/google-signin": "^13.1.0",
    "@react-native/new-app-screen": "0.85.2",
    "@react-navigation/bottom-tabs": "^7.15.10",
    "@react-navigation/drawer": "^7.9.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/stack": "^7.8.11",
    "@reduxjs/toolkit": "^2.11.2",
    "axios": "^1.15.2",
    "formik": "^2.4.9",
    "react": "19.2.3",
    "react-native": "0.85.2",
    "react-native-config": "^1.5.3",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-keychain": "^10.0.0",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.4",
    "react-native-vector-icons": "^10.3.0",
    "react-native-worklets": "0.8.3",
    "react-redux": "^9.2.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@eslint/js": "^9.39.4",
    "@react-native-community/cli": "latest",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.2",
    "@react-native/gradle-plugin": "^0.85.2",
    "@react-native/jest-preset": "0.85.2",
    "@react-native/metro-config": "0.85.2",
    "@react-native/typescript-config": "0.85.2",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-native": "^5.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^29.6.3",
    "lint-staged": "^17.0.2",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.2"
  },
  "engines": {
    "node": ">= 22.11.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "codegenConfig": {
    "name": "AppSpecs",
    "type": "all",
    "jsSrcsDir": "src/core/nativeModules",
    "android": {
      "javaPackageName": "com.ascendly"
    }
  }
}
