{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "jsx": "react-native",
    "types": ["jest"],
    "target": "esnext",
    "lib": ["esnext"],
    "baseUrl": ".",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "noEmit": true,
    "moduleResolution": "bundler",
    "paths": {
      "@app/*": ["src/app/*"],
      "@app": ["src/app"],
      "@features/*": ["src/features/*"],
      "@features": ["src/features"],
      "@shared/*": ["src/shared/*"],
      "@shared": ["src/shared"],
      "@core/*": ["src/core/*"],
      "@core": ["src/core"],
      "@store/*": ["src/store/*"],
      "@store": ["src/store"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/Pods"]
}
